#!/bin/sh

# --- Parse arguments ---
project=""
build=""
env_file=""
while [ $# -gt 0 ]; do
  case "$1" in
    --project)
      project="$2"
      shift 2
      ;;
    --build)
      build="--build"
      shift
      ;;
    --env-file)
      env_file="--env-file $2"
      shift 2
      ;;
    *)
      break
      ;;
  esac
done

# --- Resolve the real directory of this script, following symlinks ---
script="$0"
case "$script" in
  /*) ;;
  *) script="$(command -v "$script")" ;;
esac
while [ -L "$script" ]; do
  dir="$(cd -P "$(dirname "$script")" && pwd)"
  link="$(readlink "$script")"
  case "$link" in
    /*) script="$link" ;;
    *) script="$dir/$link" ;;
  esac
done
script_dir="$(cd -P "$(dirname "$script")" && pwd)"
override_file="$script_dir/docker-compose.override.yml"

if [ -n "$project" ]; then
  echo "Running with project: $project"

  # --- Build the override file ---
  # Mounts each entry from .claude-in-docker-ignore over an empty target so the
  # container cannot access those paths. Files are masked with /dev/null;
  # directories are masked with a tmpfs (empty in-memory filesystem).
  printf '# ⚠️ This file is auto-generated by claude-in-docker\n# Do not edit manually\nservices:\n  claude:\n' > "$override_file"
  has_volumes=0
  ignore_file="$project/.claude-in-docker-ignore"
  if [ -f "$ignore_file" ]; then
    while IFS= read -r pattern || [ -n "$pattern" ]; do
      case "$pattern" in '#'*|'') continue ;; esac  # skip comments and blank lines
      case "$pattern" in
        *'**'*)
          echo "Warning: '$pattern' uses ** which is not supported — skipping. Use * for single-level matching (e.g. apps/*/.env)." >&2
          continue
          ;;
      esac
      for file in "$project"/$pattern; do
        [ -e "$file" ] || continue  # skip if glob matched nothing
        rel="${file#$project}"
        if [ "$has_volumes" -eq 0 ]; then
          printf '    volumes:\n' >> "$override_file"
          has_volumes=1
        fi
        if [ -d "$file" ]; then
          printf '      - type: tmpfs\n        target: %s\n' "/home/ubuntu/\${PROJECT_NAME:-project}$rel" >> "$override_file"
        else
          printf '      - /dev/null:%s\n' "/home/ubuntu/\${PROJECT_NAME:-project}$rel" >> "$override_file"
        fi
      done
    done < "$ignore_file"
  fi
  if [ "$has_volumes" -eq 0 ]; then
    printf '    volumes: []\n' >> "$override_file"
    echo "Warning: No files found to ignore for project $project. Create a .claude-in-docker-ignore file in the project root directory to specify files to ignore."
  fi

  # --- Run claude ---
  PROJECT="$project" docker compose $env_file -f $script_dir/claude-compose.yml -f "$override_file" --project-directory "$script_dir" run --rm $build claude "$@"
else
  echo "No project specified. Exiting."
fi
